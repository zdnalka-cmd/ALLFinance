generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String            @id @default(uuid())
  name               String
  email              String            @unique
  password           String
  role               String            @default("Staff Kasir")
  created_at         DateTime          @default(now())
  dashboard_name     String?
  profile_picture    String?
  currency           String            @default("IDR")
  is_suspended       Boolean           @default(false)
  last_active        DateTime?         @default(now())
  report_exhaustions Int               @default(0)
  report_tokens      Int               @default(3)
  token_refresh_time DateTime?
  categories         Category[]
  customers          Customer[]
  expenses           Expense[]
  targets            FinancialTarget[]
  incomes            Income[]
  invoices           Invoice[]
  notifications      Notification[]
  payables           Payable[]
  products           Product[]
  purchases          Purchase[]
  receivables        Receivable[]
  reports            Report[]
  suppliers          Supplier[]
}

model FinancialTarget {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  type       String
  amount     Decimal
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Customer {
  id         String    @id @default(uuid())
  name       String
  phone      String?
  email      String?
  address    String?
  notes      String?
  created_at DateTime  @default(now())
  user_id    String?
  user       User?     @relation(fields: [user_id], references: [id])
  incomes    Income[]
  invoices   Invoice[]
}

model Supplier {
  id         String     @id @default(uuid())
  name       String
  phone      String?
  email      String?
  address    String?
  notes      String?
  created_at DateTime   @default(now())
  user_id    String?
  expenses   Expense[]
  payables   Payable[]
  purchases  Purchase[]
  user       User?      @relation(fields: [user_id], references: [id])
}

model Category {
  id       String    @id @default(uuid())
  name     String
  type     String
  user_id  String?
  user     User?     @relation(fields: [user_id], references: [id])
  expenses Expense[]
  incomes  Income[]
}

model Income {
  id               String    @id @default(uuid())
  customer_id      String?
  category_id      String
  amount           Decimal
  payment_method   String
  note             String?
  transaction_date DateTime
  user_id          String?
  category         Category  @relation(fields: [category_id], references: [id])
  customer         Customer? @relation(fields: [customer_id], references: [id])
  user             User?     @relation(fields: [user_id], references: [id])
}

model Expense {
  id               String    @id @default(uuid())
  supplier_id      String?
  category_id      String
  amount           Decimal
  note             String?
  receipt          String?
  transaction_date DateTime
  user_id          String?
  category         Category  @relation(fields: [category_id], references: [id])
  supplier         Supplier? @relation(fields: [supplier_id], references: [id])
  user             User?     @relation(fields: [user_id], references: [id])
}

model Invoice {
  id             String        @id @default(uuid())
  invoice_number String        @unique
  customer_id    String?
  total          Decimal
  discount       Decimal       @default(0)
  tax            Decimal       @default(0)
  status         String
  due_date       DateTime?
  created_at     DateTime      @default(now())
  user_id        String?
  customer       Customer?     @relation(fields: [customer_id], references: [id])
  user           User?         @relation(fields: [user_id], references: [id])
  items          InvoiceItem[]
  receivables    Receivable[]
}

model InvoiceItem {
  id         String  @id @default(uuid())
  invoice_id String
  qty        Int
  price      Decimal
  subtotal   Decimal
  product_id String
  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Receivable {
  id         String    @id @default(uuid())
  invoice_id String
  remaining  Decimal
  due_date   DateTime?
  user_id    String?
  invoice    Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [user_id], references: [id])
}

model Payable {
  id          String    @id @default(uuid())
  supplier_id String
  amount      Decimal
  due_date    DateTime?
  user_id     String?
  supplier    Supplier  @relation(fields: [supplier_id], references: [id])
  user        User?     @relation(fields: [user_id], references: [id])
}

model Product {
  id             String         @id @default(uuid())
  name           String
  category       String
  cost_price     Decimal
  retail_price   Decimal
  stock          Int            @default(0)
  created_at     DateTime       @default(now())
  user_id        String?
  description    String?
  image_url      String?
  is_digital     Boolean        @default(true)
  is_global      Boolean        @default(true)
  invoice_items  InvoiceItem[]
  user           User?          @relation(fields: [user_id], references: [id])
  purchase_items PurchaseItem[]
}

model Purchase {
  id           String         @id @default(uuid())
  po_number    String         @unique
  date         DateTime
  supplier_id  String?
  total_amount Decimal
  status       String
  created_at   DateTime       @default(now())
  user_id      String?
  supplier     Supplier?      @relation(fields: [supplier_id], references: [id])
  user         User?          @relation(fields: [user_id], references: [id])
  items        PurchaseItem[]
}

model PurchaseItem {
  id          String   @id @default(uuid())
  purchase_id String
  product_id  String
  qty         Int
  cost_price  Decimal
  subtotal    Decimal
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  purchase    Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  message    String
  type       String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(uuid())
  user_id     String
  subject     String
  message     String
  status      String   @default("Pending")
  created_at  DateTime @default(now())
  admin_reply String?
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
